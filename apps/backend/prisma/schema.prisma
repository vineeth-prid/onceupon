generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  CREATED
  STORY_GENERATING
  STORY_COMPLETE
  IMAGES_GENERATING
  IMAGES_COMPLETE
  PDF_GENERATING
  PREVIEW_READY
  PAYMENT_PENDING
  PAID
  PRINTING
  SHIPPED
  DELIVERED
  FAILED
}

enum PageStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}

enum ChildGender {
  boy
  girl
  other
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String       @id @default(uuid())
  firstName     String
  lastName      String
  email         String       @unique
  passwordHash  String?
  authProvider  AuthProvider  @default(EMAIL)
  googleId      String?      @unique
  avatarUrl     String?
  isVerified    Boolean      @default(false)
  role          UserRole     @default(USER)

  orders        Order[]
  addresses     Address[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([email])
  @@index([role])
}

model Address {
  id            String   @id @default(uuid())
  userId        String
  label         String   @default("Home")
  firstName     String
  lastName      String
  addressLine1  String
  addressLine2  String?
  city          String
  state         String?
  postalCode    String
  country       String
  phone         String?
  isDefault     Boolean  @default(false)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Order {
  id                String      @id @default(uuid())
  userId            String?
  childName         String
  childAge          Int
  childGender       ChildGender
  theme             String
  illustrationStyle String      @default("disney-character")
  customStoryPrompt String?
  photoUrl          String
  email             String?
  status            OrderStatus @default(CREATED)
  storyJson         Json?
  referenceSheetUrl    String?
  characterDescription String?
  interiorPdfUrl    String?
  coverPdfUrl       String?

  // Payment
  paymentId         String?     @unique
  razorpayOrderId   String?     @unique
  paymentProvider   String?
  amountPaid        Int?        // in smallest currency unit (paise/cents)
  currency          String?

  // Shipping
  shippingName      String?
  shippingLine1     String?
  shippingLine2     String?
  shippingCity      String?
  shippingState     String?
  shippingPostal    String?
  shippingCountry   String?
  shippingPhone     String?

  // Fulfillment
  luluJobId         String?     @unique
  trackingNumber    String?

  couponId          String?
  coupon            Coupon?     @relation(fields: [couponId], references: [id])
  discountAmount    Int?        // in paise

  user              User?       @relation(fields: [userId], references: [id])
  pages             Page[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  type          String   @default("percentage") // "flat" or "percentage"
  value         Int      // percentage (0-100) or flat amount in paise
  maxDiscount   Int?     // Max discount for percentage coupons in paise
  minAmount     Int?     // Min order amount in paise
  validFrom     DateTime @default(now())
  validTill     DateTime?
  usageLimit    Int?
  usageCount    Int      @default(0)
  active        Boolean  @default(true)
  razorpayId    String?  @unique

  orders        Order[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
}

model Page {
  id               String     @id @default(uuid())
  orderId          String
  pageNumber       Int
  text             String
  imagePrompt      String
  sceneDescription String     @default("")
  layout           String     @default("full-bleed-text-bottom")
  imageUrl         String?
  status           PageStatus @default(PENDING)
  retryCount       Int        @default(0)

  order            Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([orderId, pageNumber])
  @@index([orderId])
  @@index([status])
}
