{
  "name": "storybook-platform",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "turbo run build",
    "test:all": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "db:migrate": "pnpm --filter backend exec prisma migrate dev",
    "db:generate": "pnpm --filter backend exec prisma generate",
    "db:seed": "pnpm --filter backend exec prisma db seed",
    "redis:start": "node run-redis.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  }
}
