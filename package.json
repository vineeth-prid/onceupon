{
  "name": "storybook-platform",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "turbo run build",
    "test:all": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "db:migrate": "pnpm --filter backend exec prisma migrate dev",
    "db:generate": "pnpm --filter backend exec prisma generate",
    "db:seed": "pnpm --filter backend exec prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.9.5",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  }
}
