# ===========================================
# Backend Environment Variables
# Copy this file: cp .env.example .env
# ===========================================

# ---------- Database (PostgreSQL) ----------
# If using docker-compose from root, port is 5433 (mapped from container's 5432)
DATABASE_URL=postgresql://storybook:storybook@localhost:5433/storybook_dev

# ---------- Redis (BullMQ job queue) ----------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------- AI Services ----------
# Google Gemini - for story text generation & character description
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Replicate - for PhotoMaker image generation (paid ~$0.05/image)
# Get token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ---------- Payments (Razorpay) ----------
# Get from: https://dashboard.razorpay.com > Settings > API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------- Authentication ----------
# Secret key for signing JWT tokens (change this in production!)
JWT_SECRET=dev-secret-change-in-production

# ---------- Admin Credentials ----------
# Used by seed script to create the initial admin user (first run only).
# The seed will NOT overwrite the password if the admin already exists.
ADMIN_EMAIL=saravananmk45@gmail.com
ADMIN_PASSWORD=Admin@2026

# ---------- Email (SMTP) - Optional ----------
# Required only if you want email features (order confirmation, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Once Upon a Time
SMTP_FROM_EMAIL=

# ---------- App ----------
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
