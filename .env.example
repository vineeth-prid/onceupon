# Database
DATABASE_URL=postgresql://storybook:storybook@localhost:5432/storybook_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage (S3/R2) — optional for dev, falls back to local storage
S3_BUCKET=storybook-assets
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=  # For R2: https://<account>.r2.cloudflarestorage.com

# Gemini (story generation)
GEMINI_API_KEY=

# Replicate (image generation)
REPLICATE_API_TOKEN=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (alternative)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Lulu Print API
LULU_API_KEY=
LULU_API_SECRET=
LULU_SANDBOX=true

# App
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
